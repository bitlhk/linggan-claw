{
  "id": "market-sector-reader",
  "description": "Reader evidence pack for market/sector/company research. Adapted from Anthropic sector-reader output_schema with Unicode-friendly text fields.",
  "type": "object",
  "required": ["topic", "facts"],
  "additionalProperties": false,
  "properties": {
    "topic": {
      "type": "string",
      "maxLength": 96
    },
    "facts": {
      "type": "array",
      "maxItems": 50,
      "items": {
        "type": "object",
        "required": ["claim", "source"],
        "additionalProperties": false,
        "properties": {
          "claim": {
            "type": "string",
            "maxLength": 320
          },
          "source": {
            "type": "string",
            "maxLength": 160
          },
          "url": {
            "type": "string",
            "maxLength": 500
          },
          "date": {
            "type": "string",
            "maxLength": 32
          },
          "confidence": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          }
        }
      }
    },
    "missing_information": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "string",
        "maxLength": 160
      }
    }
  }
}
