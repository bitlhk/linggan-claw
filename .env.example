# ╔══════════════════════════════════════════════════════════════════════╗
# ║  灵虾 (LingganClaw) 环境变量配置                                      ║
# ║  标注 [必填] 的项部署前必须修改，否则服务无法启动或存在安全风险            ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ── 基础配置 ──────────────────────────────────────────────────────────
PORT=5180
NODE_ENV=production

# 应用根目录（默认为项目所在目录，一般不用改）
# APP_ROOT=/opt/linggan-platform

# ── 域名 & CORS ──────────────────────────────────────────────────────
CORS_ORIGIN=https://your-domain.com
FRONTEND_URL=https://your-domain.com
# Cookie 跨子域共享（带前导点，如 .example.com）
COOKIE_DOMAIN=.your-domain.com

# ── 数据库 [必填] ────────────────────────────────────────────────────
# ⚠️ 生产环境务必使用强密码，不要使用默认值
DATABASE_URL=mysql://linggan:YOUR_STRONG_PASSWORD@localhost:3306/linggan

# Docker Compose 部署时需要设置以下两项：
# MYSQL_ROOT_PASSWORD=<MySQL root 强密码>
# MYSQL_PASSWORD=<应用数据库用户密码，与 DATABASE_URL 中的密码一致>

# ── 认证 [必填] ──────────────────────────────────────────────────────
# ⚠️ 必须替换！可用 openssl rand -hex 32 生成
JWT_SECRET=<随机生成一个 32+ 字符的字符串>

# ── OpenClaw 配置 ─────────────────────────────────────────────────────
CLAW_PROVISION_MODE=local-script
CLAW_CHAT_MODE=local-openclaw
CLAW_OPENCLAW_HOME=/root
CLAW_REMOTE_OPENCLAW_HOME=/root
CLAW_GATEWAY_PORT=18789
# [必填] OpenClaw Gateway 认证 Token
CLAW_GATEWAY_TOKEN=<你的 openclaw gateway token>
# CLAW_OPENCLAW_JSON=/root/.openclaw/openclaw.json
# CLAW_AGENT_MODEL=glm5/glm-5

# ── 灵虾路由 ─────────────────────────────────────────────────────────
LINGGAN_CLAW_BASE_DOMAIN=demo.your-domain.com
LINGGAN_CLAW_ENTRY_SCHEME=https
DEMO_ROUTE_DOMAIN=demo.your-domain.com
# SITE_DOMAIN=www.your-domain.com

# ── 沙箱执行（Docker 隔离）────────────────────────────────────────────
SANDBOX_IMAGE=python:3.11-slim
SANDBOX_MEMORY=256m
SANDBOX_CPUS=0.5
SANDBOX_PIDS_LIMIT=50
SANDBOX_TMPFS_SIZE=50m
SANDBOX_EXEC_TIMEOUT_MS=10000
SANDBOX_MAX_OUTPUT_BYTES=65536
SANDBOX_MAX_GLOBAL=5
SANDBOX_MAX_PER_USER=2

# ── 可选功能 ──────────────────────────────────────────────────────────
# PLUS_EXEC_ENABLED=false
# INTERNAL_COLLAB_SECRET=<server-to-server secret>
# INSIGHTS_PUSH_TOKEN=<推送 token>
# TRUST_PROXY=true
# CSP_FRAME_ALLOW=
