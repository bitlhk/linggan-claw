{
  "id": "meeting-news-reader",
  "description": "Reader evidence pack for meeting preparation. Adapted from Anthropic news-reader output_schema with Unicode-friendly text fields.",
  "type": "object",
  "required": ["items"],
  "additionalProperties": false,
  "properties": {
    "topic": {
      "type": "string",
      "maxLength": 96
    },
    "items": {
      "type": "array",
      "maxItems": 50,
      "items": {
        "type": "object",
        "required": ["headline", "source"],
        "additionalProperties": false,
        "properties": {
          "headline": {
            "type": "string",
            "maxLength": 240
          },
          "summary": {
            "type": "string",
            "maxLength": 360
          },
          "source": {
            "type": "string",
            "maxLength": 160
          },
          "url": {
            "type": "string",
            "maxLength": 500
          },
          "date": {
            "type": "string",
            "maxLength": 32
          },
          "confidence": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          }
        }
      }
    },
    "missing_information": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "string",
        "maxLength": 160
      }
    }
  }
}
