{
  "_comment": "灵虾平台所需的 OpenClaw 最小配置模板。复制到 ~/.openclaw/openclaw.json 后修改。",

  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "替换为你的token_与灵虾.env的CLAW_GATEWAY_TOKEN一致"
    },
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789",
        "http://localhost:5180",
        "http://127.0.0.1:5180"
      ]
    },
    "http": {
      "endpoints": {
        "chatCompletions": true
      }
    }
  },

  "agents": {
    "defaults": {
      "model": {
        "primary": "替换为你的模型，如 deepseek/deepseek-chat"
      },
      "workspace": "~/.openclaw/workspace",
      "sandbox": {
        "mode": "all",
        "scope": "agent",
        "workspaceAccess": "rw"
      }
    }
  },

  "models": {
    "providers": {
      "_comment": "至少配一个 LLM provider，以下是 DeepSeek 示例",
      "deepseek": {
        "baseUrl": "https://api.deepseek.com",
        "apiKey": "替换为你的 DeepSeek API Key",
        "api": "openai-completions"
      }
    }
  },

  "tools": {
    "web": {
      "search": { "enabled": false },
      "fetch": { "enabled": true }
    }
  },

  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "session-memory": { "enabled": true }
      }
    }
  },

  "plugins": {
    "entries": {
      "memory-core": {
        "enabled": true,
        "config": {
          "dreaming": {
            "enabled": true,
            "frequency": "0 3 * * *"
          }
        }
      }
    }
  }
}
