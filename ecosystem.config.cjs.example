const path = require("path");

const appRoot = process.env.APP_ROOT || __dirname;
const home = process.env.HOME || "";
const extraPath = [
  home ? path.join(home, ".npm-global", "bin") : "",
  home ? path.join(home, ".local", "bin") : "",
  process.env.PATH || "",
].filter(Boolean).join(":");

module.exports = {
  apps: [
    {
      name: process.env.PM2_APP_NAME || "employee-agent",
      cwd: appRoot,
      script: "pnpm",
      args: "start",
      interpreter: "none",
      env: {
        NODE_ENV: "production",
        APP_ROOT: appRoot,
        PATH: extraPath,
      },
      autorestart: true,
      max_restarts: 10,
      restart_delay: 3000,
      max_memory_restart: process.env.PM2_MAX_MEMORY_RESTART || "1200M",
      log_date_format: "YYYY-MM-DD HH:mm:ss",
      error_file: path.join(appRoot, "logs", "pm2-error.log"),
      out_file: path.join(appRoot, "logs", "pm2-out.log"),
      merge_logs: true,
      kill_timeout: 5000,
      listen_timeout: 10000,
      watch: false,
    },
  ],
};
