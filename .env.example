# ╔══════════════════════════════════════════════════════════════════════╗
# ║  员工智能体 环境变量配置                                      ║
# ║  标注 [必填] 的项部署前必须修改，否则服务无法启动或存在安全风险            ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ── 基础配置 ──────────────────────────────────────────────────────────
PORT=5180

# ── 访问方式 ──────────────────────────────────────────────────────────
# 本机访问: http://localhost:5180  (CORS_ORIGIN 和 FRONTEND_URL 设为 http://localhost:5180, COOKIE_DOMAIN 留空)
# 内网访问: http://192.168.x.x:5180
# 域名访问: https://your-domain.com
CORS_ORIGIN=http://localhost:5180
FRONTEND_URL=http://localhost:5180
# Cookie 跨子域共享（本机/内网部署留空，域名部署设 .example.com）
COOKIE_DOMAIN=

# ── 数据库 [必填] ────────────────────────────────────────────────────
# Docker Compose 部署: 使用下面的默认值即可（MySQL 容器自动创建）
# 手动部署: 改为你的 MySQL 地址
DATABASE_URL=mysql://linggan:YOUR_STRONG_PASSWORD@localhost:3306/linggan

# Docker Compose 部署时需要设置：
# MYSQL_ROOT_PASSWORD=<MySQL root 强密码>
# MYSQL_PASSWORD=<应用数据库用户密码，与 DATABASE_URL 中的密码一致>

# ── 认证 [必填] ──────────────────────────────────────────────────────
# setup.sh 会自动生成，也可手动: openssl rand -hex 32
JWT_SECRET=

# ── 安全 [必填] ──────────────────────────────────────────────────────
# 租户隔离密钥，setup.sh 自动生成
# 不设置会使用弱默认值，存在安全风险
TENANT_SECRET=
INTERNAL_API_KEY=
# 独立部署默认可关闭邮箱验证码；配置 SMTP 后建议改为 true
EMAIL_VERIFICATION_REQUIRED=false

# ── OpenClaw 配置 ─────────────────────────────────────────────────────
# OpenClaw 是主聊天的核心依赖，需提前安装: npm install -g openclaw
CLAW_PROVISION_MODE=local-script
CLAW_CHAT_MODE=local-openclaw
# 同机部署时填写运行灵虾/OpenClaw 的系统用户 home 目录。
# 例如 root 部署填 /root，ubuntu 部署填 /home/ubuntu。
# 也兼容直接填写 .openclaw 目录，例如 /home/ubuntu/.openclaw。
CLAW_OPENCLAW_HOME=/home/ubuntu
CLAW_REMOTE_OPENCLAW_HOME=/home/ubuntu
CLAW_GATEWAY_PORT=18789
# Gateway 认证 Token [必填] — 必须与 openclaw.json 里的 gateway.auth.token 一致
# setup.sh 会自动生成并同步到 OpenClaw 配置
CLAW_GATEWAY_TOKEN=
# 远端 Gateway 地址（单机部署保持 127.0.0.1）
CLAW_REMOTE_HOST=127.0.0.1

# Hermes profiles path; either /home/ubuntu/.hermes or /home/ubuntu/.hermes/profiles is accepted.
# HERMES_HOME=/home/ubuntu/.hermes

# ── 业务 Agent（可选）────────────────────────────────────────────────
# 远端 Agent Gateway 地址（如果业务 agent 部署在其他机器）
# CLAW_REMOTE_GATEWAY_HOST=127.0.0.1
# Hermes Agent skills 目录（Hermes 式业务 agent 需要）
# HERMES_SKILLS_ROOT=/home/ubuntu/.hermes/skills
# 内置金融演示 Preset 默认关闭。只有在你明确部署了对应业务工具链时才打开。
ENABLE_BUILTIN_BUSINESS_AGENT_PRESETS=false

# ── 实验工作台（可选）───────────────────────────────────────────────
# 开启后仅 admin 可访问 /task-workbench-lab；ALLOW_USER_IDS 留空表示所有 admin。
TASK_WORKBENCH_LAB_ENABLED=false
TASK_WORKBENCH_LAB_ALLOW_USER_IDS=
TASK_WORKBENCH_LAB_MAX_AGENTS=3
# TASK_WORKBENCH_LAB_KILL_FILE=/tmp/lingxia-task-workbench-lab.disabled

# ── 平台记忆（Hermes 式策展记忆）─────────────────────────────────────
# 自动从对话中提取用户偏好，需要 DeepSeek API Key
MEMORY_ENABLED=true
MEMORY_EXTRACT_INTERVAL=5
MEMORY_CHAR_LIMIT=2200
MEMORY_USER_CHAR_LIMIT=1375
DEEPSEEK_API_KEY=

# ── 灵虾路由 ─────────────────────────────────────────────────────────
# 域名部署时设置，本机/内网部署可留空
# LINGGAN_CLAW_BASE_DOMAIN=demo.your-domain.com
# LINGGAN_CLAW_ENTRY_SCHEME=https
# DEMO_ROUTE_DOMAIN=demo.your-domain.com

# ── 沙箱执行（Docker 隔离，可选）──────────────────────────────────────
SANDBOX_IMAGE=python:3.11-slim
SANDBOX_MEMORY=256m
SANDBOX_CPUS=0.5
SANDBOX_PIDS_LIMIT=50
SANDBOX_TMPFS_SIZE=50m
SANDBOX_EXEC_TIMEOUT_MS=10000
SANDBOX_MAX_OUTPUT_BYTES=65536
SANDBOX_MAX_GLOBAL=5
SANDBOX_MAX_PER_USER=2
