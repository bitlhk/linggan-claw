{
  "name": "linggan-claw",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm run dev:client & pnpm run dev:server",
    "dev:client": "vite --config client/vite.config.ts",
    "dev:server": "NODE_ENV=development tsx watch server/_core/index.ts",
    "build": "pnpm run build:client",
    "build:client": "vite build --config client/vite.config.ts --mode production",
    "start": "NODE_ENV=production tsx server/_core/index.ts",
    "start:client": "vite preview --config client/vite.config.ts",
    "start:server": "NODE_ENV=production tsx server/_core/index.ts",
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run",
    "db:push": "drizzle-kit generate && drizzle-kit migrate",
    "db:reset": "tsx scripts/reset-db.ts && pnpm exec drizzle-kit push",
    "db:add-blocked-enum": "tsx scripts/add-blocked-to-ip-management-enum.ts",
    "db:backup-users": "tsx scripts/backup-user-data.ts",
    "stats:backfill": "tsx scripts/visit-stats-backfill.ts",
    "stats:reconcile": "tsx scripts/visit-stats-reconcile.ts",
    "compress:images": "tsx scripts/compress-images.ts",
    "convert:webp": "tsx scripts/convert-to-webp.ts"
  },
